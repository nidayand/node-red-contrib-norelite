{
  "name": "@nidayand/node-red-contrib-norelite",
  "version": "3.0.0",
  "description": "A set of Node-Red nodes to ease the implementation of your home automation requirements",
  "author": {
    "name": "nidayand",
    "email": "pggithub@gothager.se"
  },
  "dependencies": {
    "date-utils": "^1.2.21",
    "events": "^3.3.0",
    "underscore": "^1.13.7",
    "when": "^3.7.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nidayand/node-red-contrib-norelite.git"
  },
  "license": "Apache-2.0",
  "keywords": [],
  "node-red": {
    "nodes": {
      "nrl-config": "core/nrl-config.js",
      "nrl-eval in": "core/nrl-eval.js",
      "nrl-gate in": "util/nrl-gate.js",
      "nrl-source out": "core/nrl-source.js",
      "nrl-switch out": "core/nrl-switch.js",
      "nrl-limit": "core/nrl-limit.js",
      "nrl-dayslimit in": "util/nrl-dayslimit.js",
      "nrl-hold in": "util/nrl-hold.js",
      "nrl-route in": "util/nrl-route.js",
      "nrl-timelimit in": "util/nrl-timelimit.js",
      "nrl-value in": "util/nrl-value.js",
      "nrl-set in": "util/nrl-set.js",
      "nrl-on in": "core/nrl-on.js",
      "light-out": "home-assistant/light-out.js",
      "switch-out": "home-assistant/switch-out.js"
    },
    "version": "4.0.0"
  },
  "scripts": {
    "dev": "nodemon --watch . --ext js,json --exec \"node-red -u .\""
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
